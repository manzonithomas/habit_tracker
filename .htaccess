# Nega accesso ai file sensibili
<FilesMatch "^(\.env|config\.php|db\.sql|\.git)">
    Require all denied
</FilesMatch>

# Impostazioni PHP sicure
<IfModule mod_php.c>
    php_value display_errors 0
    php_value log_errors 1
</IfModule>

# Sicurezza Headers & CSP
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.2/dist/confetti.browser.min.js; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"
</IfModule>

